# Copy to `.env.local` and fill in. `.env.local` is gitignored.
#
# Both of these ship to the browser — Vite inlines every VITE_-prefixed variable
# into the bundle. That is fine and intended for these two: the anon key is a
# public identifier, and what it can actually read is decided by the RLS policies
# in supabase/migrations/, not by keeping the key secret.
#
# The SERVICE ROLE key is the opposite. It bypasses RLS completely. It must never
# appear in this file, never carry a VITE_ prefix, and never reach the frontend —
# it belongs only in /etc/frc5805-backup.env on the backup host. See docs/BACKUP.md.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — build-time only, used by scripts/fetch-tba.mjs. Not exposed to the
# browser precisely because it has no VITE_ prefix.
#
# The name must be exactly TBA_KEY: that is what fetch-tba.mjs reads. This file
# previously said TBA_API_KEY, which meant anyone following it got a build-time
# fetch that silently no-op'd and kept stale live.json data — the script treats
# a missing key as "skip quietly", so there was nothing to notice.
TBA_KEY=
